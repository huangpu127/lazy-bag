# 懒人包后端环境变量配置
# 复制此文件为 .env 并填入你的 API 密钥

# Tavily API Key（首选搜索服务）
# 获取地址：https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# SerpAPI Key（备用搜索服务）
# 获取地址：https://serpapi.com/
SERP_API_KEY=your_serpapi_key_here

# Anthropic Claude API Key（AI 生成首选）
# 获取地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic API Base URL（可选，使用代理时配置）
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenRouter API Key（AI 生成备用）
# 获取地址：https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# CORS 允许的域名（多个域名用逗号分隔）
# 生产环境建议设置为具体的 Chrome 扩展 ID 和前端域名
ALLOWED_ORIGINS=*

# 可选：端口配置（本地开发使用）
# PORT=8001
