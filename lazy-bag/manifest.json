{
  "manifest_version": 3,
  "name": "懒人包",
  "version": "1.1.0",
  "description": "选中网页上的关键词，显示1-2句话的懒人包解释（基于可靠信源）",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8001/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_title": "懒人包",
    "default_popup": "options.html"
  },
  "options_page": "options.html"
}